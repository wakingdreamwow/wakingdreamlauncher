{
  "name": "wakingdream-launcher",
  "version": "0.2.5",
  "description": "Cross-platform launcher for Wakingdream WoW 3.3.5a private server",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "start": "electron ."
  },
  "author": "Wakingdream Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "cc.wakingdream.launcher",
    "productName": "Wakingdream Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/logo/icon-512.png"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/logo/icon-256.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/logo/icon-512.png",
      "category": "Game",
      "artifactName": "wakingdream-launcher-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/logo/icon-512.png"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://patches.wakingdream.cc/launcher/"
      }
    ]
  }
}
